# OpenAI API 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 阿里云 DashScope API 配置（通义千问）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# 通用配置
TEMPERATURE=0.3
MAX_TOKENS=2000
VECTOR_DB_TYPE=faiss
CHROMA_PERSIST_DIR=./chroma_db
FAISS_INDEX_PATH=./faiss_index
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
CHUNK_SIZE=420
CHUNK_OVERLAP=80
TOP_K_RETRIEVAL=3
RETRIEVAL_MODE=hybrid
HYBRID_CANDIDATE_MULTIPLIER=6
HYBRID_VECTOR_WEIGHT=0.55
HYBRID_BM25_WEIGHT=0.45
MMR_ENABLED=true
MMR_LAMBDA=0.65
MMR_FETCH_K=20
MMR_MIN_CANDIDATES=10
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MIN_CANDIDATES=8
MAX_RERANK_CANDIDATES=12
RAG_PRELOAD_ON_STARTUP=false
RAG_WARMUP_BACKGROUND=true
RAG_WARMUP_LOAD_RERANKER=false
ENABLE_LOW_LATENCY_RETRIEVAL=true
FAST_FETCH_K_CAP=12
FAISS_DOCSTORE_CACHE_FILE=./faiss_index/docs_cache.jsonl
FAISS_SIGNATURE_FILE=./faiss_index/signature.sha256
FAISS_TRUST_LEGACY_INDEX=false
MAX_CONVERSATION_HISTORY=10
LOG_LEVEL=INFO
RESPONSE_TIMEOUT=5

# 选择使用的 API 提供商（openai 或 dashscope）
API_PROVIDER=openai
